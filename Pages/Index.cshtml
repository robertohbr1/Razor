@page
@model RazorDataPresentation.Pages.IndexModel
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dados da Tabela</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <h1>Apresentação dos Dados</h1>
    <form method="get" id="orderForm">
        <input type="hidden" name="order" id="orderInput" value="@Model.SelectedOrder" />
        <label><input type="radio" name="orderRadio" value="IE" @(Model.SelectedOrder == "IE" ? "checked" : "") onchange="changeOrder(this.value)"> IE</label>
        <label><input type="radio" name="orderRadio" value="CNPJ" @(Model.SelectedOrder == "CNPJ" ? "checked" : "") onchange="changeOrder(this.value)"> CNPJ</label>
    </form>
    <table id="data-table">
        <thead>
            <tr>
                @foreach (var column in Model.TableColumns.Where(c => c.ativo))
                {
                    <th data-col="@column.nome" style="text-align:@Model.GetAlignmentCss(column.alinhamento)" title="@column.textoToolTip">@column.texto</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Empresas)
            {
                <tr>
                    @foreach (var column in Model.TableColumns.Where(c => c.ativo))
                    {
                        var value = item.GetType().GetProperty(column.nome)?.GetValue(item);
                        var formattedValue = Model.FormatValue(value, column.tipo);
                        
                        <td data-col="@column.nome" style="text-align:@Model.GetAlignmentCss(column.alinhamento)">
                            @if (!string.IsNullOrEmpty(column.Link))
                            {
                                var linkData = Model.GetLinkData(item, column.LinkFields);
                                <a href="#" onclick="handleLinkAction('@column.Link', '@linkData'); return false;" style="cursor: pointer; color: blue; text-decoration: underline;">
                                    @formattedValue
                                </a>
                            }
                            else
                            {
                                @formattedValue
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
    <script>
        function changeOrder(value) {
            document.getElementById('orderInput').value = value;
            document.getElementById('orderForm').submit();
        }

        function handleLinkAction(action, data) {
            const parts = data.split('|');
            
            if (action === 'ShowInfo') {
                const [ie, nome] = parts;
                alert(`IE: ${ie}\nNome: ${nome}`);
            }
            else if (action === 'ShowCNPJ') {
                const cnpj = parts[0];
                alert(`CNPJ: ${cnpj}`);
            }
            // Adicione outros tipos de ações aqui conforme necessário
            // else if (action === 'OutraAcao') { ... }
        }
    </script>
</body>
</html>
